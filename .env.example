# Web
VITE_API_BASE_URL=http://localhost:8080

# Mobile
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_WEB_BASE_URL=http://localhost:5273

# API
APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/my_notion_go?sslmode=disable
CORS_ALLOWED_ORIGINS=http://localhost:5273,http://localhost:8081
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Local infrastructure
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=my_notion_go_chunks

# AI / LLM, optional for non-AI document smoke tests.
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# Smoke tests
SMOKE_EMAIL=demo@example.com
SMOKE_PASSWORD=password123
SMOKE_REALTIME_TIMEOUT_MS=8000
