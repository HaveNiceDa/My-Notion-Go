{
  "name": "my-notion-go",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "start:web": "concurrently -n web,api,worker -c cyan,green,magenta \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:worker\"",
    "start:mobile": "concurrently -n web,api,worker -c cyan,green,magenta \"pnpm dev:mobile\" \"pnpm dev:api\" \"pnpm dev:worker\"",
    "dev:web": "pnpm --filter @my-notion-go/web dev",
    "dev:mobile": "pnpm --filter @my-notion-go/mobile start",
    "dev:api": "go run ./services/api/cmd/api",
    "dev:worker": "go run ./services/api/cmd/worker",
    "build": "pnpm build:web && pnpm build:api && pnpm build:worker",
    "build:web": "pnpm --filter @my-notion-go/web build",
    "build:api": "go build -o ./services/api/bin/api ./services/api/cmd/api",
    "build:worker": "go build -o ./services/api/bin/worker ./services/api/cmd/worker",
    "migrate:api": "go run ./services/api/cmd/migrate",
    "typecheck": "pnpm --filter @my-notion-go/web typecheck",
    "typecheck:mobile": "pnpm --filter @my-notion-go/mobile typecheck",
    "lint": "pnpm --filter @my-notion-go/web lint",
    "lint:mobile": "pnpm --filter @my-notion-go/mobile lint",
    "e2e:web": "playwright test",
    "format:go": "gofmt -w ./services/api",
    "test:go": "go test ./services/api/...",
    "smoke:api:documents": "node ./scripts/smoke-documents-api.mjs",
    "smoke:api:realtime": "node ./scripts/smoke-realtime-api.mjs",
    "smoke:api:ai-chat": "node ./scripts/smoke-ai-chat-api.mjs",
    "smoke:api:embedding": "node ./scripts/smoke-embedding-qdrant.mjs",
    "smoke:api:rag": "node ./scripts/smoke-rag-api.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.2.1"
  },
  "pnpm": {
    "overrides": {
      "@tiptap/core": "3.22.4",
      "@tiptap/extension-bold": "3.22.4",
      "@tiptap/extension-bubble-menu": "3.22.3",
      "@tiptap/extension-code": "3.22.4",
      "@tiptap/extension-floating-menu": "3.22.3",
      "@tiptap/extension-horizontal-rule": "3.22.4",
      "@tiptap/extension-italic": "3.22.4",
      "@tiptap/extension-paragraph": "3.22.4",
      "@tiptap/extension-strike": "3.22.4",
      "@tiptap/extension-text": "3.22.4",
      "@tiptap/extension-underline": "3.22.4",
      "@tiptap/extensions": "3.22.4",
      "@tiptap/pm": "3.22.4",
      "@tiptap/react": "3.22.3",
      "prosemirror-model": "1.25.4",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
